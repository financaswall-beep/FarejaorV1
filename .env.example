# Farejador — env vars
# Copy to `.env` (gitignored) and fill in real values. See docs/CONFIG.md for the full inventory.

# --- Runtime ---
NODE_ENV=development
FAREJADOR_ENV=prod
PORT=3000
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
DATABASE_POOL_MAX=10
DATABASE_SSL=false
# PEM string do CA do Supabase. Obrigatório quando DATABASE_SSL=true e FAREJADOR_ENV=prod.
# Obter em: Supabase Dashboard → Settings → Database → SSL Certificate (Download).
# Formato: valor de uma linha com \n substituindo as quebras reais:
#   DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\nMIIB...\n-----END CERTIFICATE-----\n"
# Em dev/staging pode deixar vazio (aceita cert sem validação). Em prod não pode.
DATABASE_CA_CERT=

# --- Chatwoot webhook ---
CHATWOOT_HMAC_SECRET=replace-with-real-secret
CHATWOOT_WEBHOOK_MAX_AGE_SECONDS=300

# --- Chatwoot API (used by admin reconcile) ---
CHATWOOT_API_BASE_URL=https://chatwoot.example.com/api/v1
CHATWOOT_API_TOKEN=replace-with-real-token
CHATWOOT_ACCOUNT_ID=1

# --- Admin auth ---
ADMIN_AUTH_TOKEN=generate-a-long-random-string

# --- Normalization filter ---
# Comma-separated list of Chatwoot event types to mark as `skipped` (raw is preserved).
# Use during shadow mode to ignore noisy event types like `message_updated`.
# Leave empty to process every event type.
SKIP_EVENT_TYPES=
