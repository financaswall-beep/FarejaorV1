{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_version": "moto-pneus-v1",
  "schema_owner": "Wallace - loja de pneus",
  "locale": "pt-BR",
  "description": "Schema fechado de fact_keys que a LLM Organizadora pode extrair em conversas de venda de pneus de moto. Atualizado em 2026-04-27.",

  "promotion_rules": {
    "value_storage": "TEXT no v1, promove para ENUM apos 4-8 semanas de taxonomia estavel",
    "evidence": "obrigatoria para todo fact extraido por LLM",
    "confidence_min": 0.55,
    "supersede_on_value_change": true
  },

  "fact_keys": {
    "moto_marca": {
      "category": "vehicle",
      "description": "Marca da moto do cliente",
      "value_type": "string",
      "value_constraints": {
        "examples": ["Honda", "Yamaha", "Suzuki", "Kawasaki", "Bajaj", "BMW", "Royal Enfield", "Harley-Davidson"],
        "normalization": "title_case",
        "max_length": 50
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred", "confirmado_cliente", "corrected"]
    },

    "moto_modelo": {
      "category": "vehicle",
      "description": "Modelo da moto. Pode vir junto com cilindrada (CG 160, Bros 160).",
      "value_type": "string",
      "value_constraints": {
        "examples": ["CG 160", "Bros 160", "Fan 160", "Factor 150", "XRE 300", "Fazer 250", "MT-03", "CB 500X"],
        "normalization": "as_spoken",
        "max_length": 80
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred", "confirmado_cliente", "corrected"]
    },

    "moto_ano": {
      "category": "vehicle",
      "description": "Ano da moto",
      "value_type": "integer",
      "value_constraints": {
        "min": 1980,
        "max": 2030
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "moto_cilindrada": {
      "category": "vehicle",
      "description": "Cilindrada em cc, quando dita explicitamente",
      "value_type": "integer",
      "value_constraints": {
        "min": 50,
        "max": 2500
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred", "confirmado_cliente"]
    },

    "moto_uso": {
      "category": "vehicle",
      "description": "Uso principal da moto",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["trabalho", "passeio", "delivery", "aplicativo", "viagem", "trilha", "esporte", "uso_misto"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred", "confirmado_cliente"]
    },

    "medida_pneu": {
      "category": "product_search",
      "description": "Medida de pneu solicitada (formato 140/70-17 ou similar)",
      "value_type": "string",
      "value_constraints": {
        "pattern": "^[0-9]{2,3}/[0-9]{2,3}-[0-9]{2}$",
        "examples": ["140/70-17", "100/80-17", "90/90-18", "120/70-17"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente", "corrected"]
    },

    "posicao_pneu": {
      "category": "product_search",
      "description": "Posicao do pneu",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["dianteiro", "traseiro", "ambos"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred", "confirmado_cliente"]
    },

    "marca_pneu_preferida": {
      "category": "product_search",
      "description": "Marca de pneu que o cliente quer",
      "value_type": "string",
      "value_constraints": {
        "examples": ["Pirelli", "Michelin", "Maggion", "Levorin", "Rinaldi", "Metzeler", "Bridgestone", "Dunlop"],
        "normalization": "title_case"
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "marca_pneu_recusada": {
      "category": "product_search",
      "description": "Marca de pneu que o cliente nao quer",
      "value_type": "string",
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "quantidade_pneus": {
      "category": "product_search",
      "description": "Quantos pneus o cliente quer",
      "value_type": "integer",
      "value_constraints": {
        "min": 1,
        "max": 4
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "intencao_cliente": {
      "category": "intent",
      "description": "Intencao primaria do cliente",
      "value_type": "enum",
      "value_constraints": {
        "allowed": [
          "comprar_pneu",
          "consultar_preco",
          "consultar_estoque",
          "consultar_compatibilidade",
          "consultar_entrega",
          "trocar_pneu",
          "duvida_geral",
          "reclamacao",
          "garantia",
          "concorrente_orcamento",
          "outro"
        ]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred"]
    },

    "motivo_compra": {
      "category": "intent",
      "description": "Por que o cliente quer comprar agora",
      "value_type": "enum",
      "value_constraints": {
        "allowed": [
          "pneu_furou",
          "pneu_careca",
          "troca_preventiva",
          "viagem_proxima",
          "trabalho_diario",
          "delivery_app",
          "seguranca",
          "indicacao_mecanico",
          "promocao",
          "outro"
        ]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred"]
    },

    "urgencia": {
      "category": "intent",
      "description": "Nivel de urgencia",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["alta", "media", "baixa"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred"]
    },

    "preferencia_principal": {
      "category": "preference",
      "description": "O que pesa mais na decisao do cliente",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["preco", "durabilidade", "marca_conhecida", "pronta_entrega", "qualidade", "indicacao", "nao_sabe"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "inferred"]
    },

    "faixa_preco_desejada": {
      "category": "preference",
      "description": "Faixa de preco que o cliente sinalizou",
      "value_type": "string",
      "value_constraints": {
        "examples": ["ate 200", "200-300", "300-500", "acima de 500", "qualquer"]
      },
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "aceita_alternativa": {
      "category": "preference",
      "description": "Se aceita pneu de marca/modelo alternativo",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "bairro_mencionado": {
      "category": "delivery",
      "description": "Bairro citado pelo cliente",
      "value_type": "string",
      "value_constraints": {
        "max_length": 100,
        "normalization": "title_case"
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "municipio_mencionado": {
      "category": "delivery",
      "description": "Municipio/cidade citado",
      "value_type": "string",
      "value_constraints": {
        "max_length": 100,
        "normalization": "title_case"
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "modalidade_entrega": {
      "category": "delivery",
      "description": "Como o cliente quer receber",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["entrega", "retirada", "indefinido"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "perguntou_entrega_hoje": {
      "category": "delivery",
      "description": "Cliente perguntou se entrega no mesmo dia",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "forma_pagamento": {
      "category": "payment",
      "description": "Forma de pagamento mencionada",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["pix", "cartao_credito", "cartao_debito", "dinheiro", "boleto", "indefinido"]
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "pediu_desconto": {
      "category": "negotiation",
      "description": "Cliente pediu desconto explicito",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "perguntou_parcelamento": {
      "category": "negotiation",
      "description": "Cliente perguntou parcelas",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "achou_caro": {
      "category": "negotiation",
      "description": "Cliente expressou que preco esta caro",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "concorrente_citado": {
      "category": "competition",
      "description": "Nome do concorrente mencionado",
      "value_type": "string",
      "value_constraints": {
        "max_length": 100
      },
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "preco_concorrente": {
      "category": "competition",
      "description": "Preco que o concorrente ofereceu",
      "value_type": "number",
      "value_constraints": {
        "min": 0
      },
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "produto_oferecido": {
      "category": "outcome",
      "description": "Produto que o agente ofertou (referencia textual)",
      "value_type": "string",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "produto_aceito": {
      "category": "outcome",
      "description": "Cliente aceitou a oferta",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    },

    "produto_recusado_motivo": {
      "category": "outcome",
      "description": "Motivo da recusa do produto",
      "value_type": "enum",
      "value_constraints": {
        "allowed": ["preco", "marca", "prazo", "estoque", "duvida", "comprou_concorrente", "outro"]
      },
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "pediu_humano": {
      "category": "operational",
      "description": "Cliente solicitou atendimento humano",
      "value_type": "boolean",
      "evidence_required": true,
      "truth_types": ["observed"]
    },

    "nome_cliente": {
      "category": "identity",
      "description": "Nome do cliente, quando informado",
      "value_type": "string",
      "value_constraints": {
        "max_length": 120,
        "normalization": "title_case",
        "pii": true
      },
      "evidence_required": true,
      "truth_types": ["observed", "confirmado_cliente"]
    }
  },

  "categories_summary": {
    "vehicle": "Dados do veiculo do cliente",
    "product_search": "O que ele esta procurando",
    "intent": "Intencao e motivacao",
    "preference": "Preferencias declaradas",
    "delivery": "Entrega e localizacao",
    "payment": "Pagamento",
    "negotiation": "Sinais de negociacao",
    "competition": "Concorrencia",
    "outcome": "Desfecho da conversa",
    "operational": "Operacional do atendimento",
    "identity": "Identidade (PII)"
  },

  "validation_notes": [
    "Toda fact_key extraida pela LLM Organizadora deve passar por validacao Zod no worker.",
    "Se a LLM retornar uma chave fora desta whitelist, e rejeitada e gera ops.agent_incidents do tipo schema_violation.",
    "evidence_text deve ser literal quando truth_type = observed; pode ser interpretativo quando truth_type = inferred.",
    "Mudanca de valor (CG 160 -> Bros 160) gera nova linha em conversation_facts e supersede a anterior, nao UPDATE.",
    "Confirmacao explicita (cliente respondeu 'sim' a uma pergunta direta) tem truth_type = confirmado_cliente e e gravada por action handler, nao pela LLM Organizadora.",
    "Campos com pii=true sao logados com mascaramento."
  ]
}
