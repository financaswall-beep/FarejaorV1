# Farejador - env vars
# Copy to `.env` (gitignored) and fill in real values. See docs/CONFIG.md for the full inventory.

# --- Runtime ---
NODE_ENV=development
FAREJADOR_ENV=prod
PORT=3000
LOG_LEVEL=debug

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:password@host:6543/postgres
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# --- Chatwoot webhook ---
CHATWOOT_HMAC_SECRET=replace-with-real-secret
CHATWOOT_WEBHOOK_MAX_AGE_SECONDS=300

# --- Chatwoot API (used by admin reconcile) ---
CHATWOOT_API_BASE_URL=https://chatwoot.example.com/api/v1
CHATWOOT_API_TOKEN=replace-with-real-token
CHATWOOT_ACCOUNT_ID=1

# --- Admin auth ---
ADMIN_AUTH_TOKEN=generate-a-long-random-string

# --- Normalization filter ---
# Comma-separated list of Chatwoot event types to mark as `skipped` (raw is preserved).
# Use during shadow mode to ignore noisy event types like `message_updated`.
# Leave empty to process every event type.
SKIP_EVENT_TYPES=

# --- Organizadora (Fase 3) ---
# Ligue após aplicar migrations 0013-0021 em staging/prod.
# Shadow Assistido: ORGANIZADORA_ENABLED=true, ATENDENTE_ENABLED=false (padrão).
ORGANIZADORA_ENABLED=false
OPENAI_API_KEY=sk-replace-with-real-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000
# Debounce: aguarda X segundos após a última mensagem antes de processar.
# Garante que rafágas de mensagens geram só 1 chamada LLM por conversa.
ORGANIZADORA_DEBOUNCE_SECONDS=90
ORGANIZADORA_POLL_INTERVAL_MS=5000

# --- Atendente Shadow Worker (Sprint 5) ---
# Log-only: nao gera texto, nao chama Generator e nao envia Chatwoot.
ATENDENTE_SHADOW_ENABLED=false
ATENDENTE_SHADOW_POLL_INTERVAL_MS=5000
PLANNER_LLM_ENABLED=false
PLANNER_OPENAI_API_KEY=sk-replace-with-planner-key
PLANNER_MODEL=gpt-4o-mini
